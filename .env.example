# Copy this file to ".env" and fill in your real values.
# The .env file is git-ignored and must never be committed.
#
# This project uses Vertex AI (Gemini) - there is NO API key.
# Authentication uses Application Default Credentials (ADC):
#   - Locally: run 'gcloud auth application-default login'
#   - On Cloud Run: the service account identity is used automatically

# Required: your Google Cloud project id
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# Optional: Vertex AI region (defaults to us-central1)
GOOGLE_CLOUD_LOCATION=us-central1

# Optional: override the default Gemini model
GEMINI_MODEL=gemini-2.0-flash-001
